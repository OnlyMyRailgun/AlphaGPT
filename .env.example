# AlphaGPT Configuration Template

# --- Database (PostgreSQL) ---
DB_USER=postgres
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=crypto_quant

# --- Data Provider ---
# Supported values: birdeye, dexscreener
DATA_PROVIDER=birdeye

# Birdeye key is only required when DATA_PROVIDER=birdeye
# Get your API key at https://docs.birdeye.so/
BIRDEYE_API_KEY=your_birdeye_api_key_here

# Optional: override DexScreener endpoints if their chart API path changes
# DEXSCREENER_API_BASE=https://api.dexscreener.com
# DEXSCREENER_CHART_API_URL=https://io.dexscreener.com/dex/chart/amm/v3

# --- Solana Execution ---
# Your Solana Wallet Private Key (Base58 format preferred)
SOLANA_PRIVATE_KEY=your_solana_private_key_here
# Solana RPC URL (QuickNode, Helius, or Mainnet-beta)
QUICKNODE_RPC_URL=https://api.mainnet-beta.solana.com

# --- Logging ---
# LOG_LEVEL=INFO
